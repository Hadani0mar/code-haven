<Window x:Class="SqlConnectionTester.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="مختبر اتصال SQL Server"
        Height="680" Width="620"
        MinHeight="620" MinWidth="580"
        WindowStartupLocation="CenterScreen"
        Background="#F5F7FA"
        FlowDirection="RightToLeft"
        FontFamily="Segoe UI">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#1E3A5F" Padding="24,18">
            <StackPanel>
                <TextBlock Text="&#x1F50C; مختبر اتصال SQL Server"
                           FontSize="22" FontWeight="Bold"
                           Foreground="White" HorizontalAlignment="Center"/>
                <TextBlock Text="اختبر الاتصال بقاعدة بيانات SQL Server بسهولة"
                           FontSize="12" Foreground="#90CAF9"
                           HorizontalAlignment="Center" Margin="0,4,0,0"/>
            </StackPanel>
        </Border>

        <!-- Main Content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="24,20,24,10">

                <!-- Server Card -->
                <Border Background="White" CornerRadius="12" Padding="20"
                        Margin="0,0,0,16">
                    <Border.Effect>
                        <DropShadowEffect Color="#000000" Opacity="0.06" BlurRadius="12" ShadowDepth="2"/>
                    </Border.Effect>
                    <StackPanel>
                        <TextBlock Text="&#x2699;&#xFE0F; إعدادات الاتصال" FontSize="15" FontWeight="Bold"
                                   Foreground="#1E3A5F" Margin="0,0,0,16"/>

                        <TextBlock Text="اسم السيرفر أو IP" Style="{StaticResource FieldLabel}"/>
                        <TextBox x:Name="TxtServer" Style="{StaticResource ModernTextBox}"
                                 Text="192.168.1.100"
                                 Margin="0,0,0,14"/>

                        <TextBlock Text="اسم قاعدة البيانات" Style="{StaticResource FieldLabel}"/>
                        <TextBox x:Name="TxtDatabase" Style="{StaticResource ModernTextBox}"
                                 Margin="0,0,0,14"/>

                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="المنفذ (Port)" Style="{StaticResource FieldLabel}"
                                       VerticalAlignment="Center"/>
                            <CheckBox x:Name="ChkCustomPort" Grid.Column="1"
                                      Content="تخصيص المنفذ" FontFamily="Segoe UI" FontSize="12"
                                      Foreground="#6B7A8D" VerticalAlignment="Center"
                                      Checked="ChkCustomPort_Changed" Unchecked="ChkCustomPort_Changed"/>
                        </Grid>
                        <TextBox x:Name="TxtPort" Style="{StaticResource ModernTextBox}"
                                 Text="1433" IsEnabled="False" Foreground="#9E9E9E"
                                 Margin="0,0,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Authentication Card -->
                <Border Background="White" CornerRadius="12" Padding="20"
                        Margin="0,0,0,16">
                    <Border.Effect>
                        <DropShadowEffect Color="#000000" Opacity="0.06" BlurRadius="12" ShadowDepth="2"/>
                    </Border.Effect>
                    <StackPanel>
                        <TextBlock Text="&#x1F510; نوع المصادقة" FontSize="15" FontWeight="Bold"
                                   Foreground="#1E3A5F" Margin="0,0,0,16"/>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                            <RadioButton x:Name="RbWindowsAuth" Content="Windows Authentication"
                                         FontFamily="Segoe UI" FontSize="13" Foreground="#1A2B3C"
                                         IsChecked="True" Margin="0,0,24,0"
                                         Checked="AuthType_Changed"/>
                            <RadioButton x:Name="RbSqlAuth" Content="SQL Server Authentication"
                                         FontFamily="Segoe UI" FontSize="13" Foreground="#1A2B3C"
                                         Checked="AuthType_Changed"/>
                        </StackPanel>

                        <StackPanel x:Name="SqlAuthPanel" Visibility="Collapsed">
                            <TextBlock Text="اسم المستخدم" Style="{StaticResource FieldLabel}"/>
                            <TextBox x:Name="TxtUsername" Style="{StaticResource ModernTextBox}"
                                     Text="sa" Margin="0,0,0,14"/>

                            <TextBlock Text="كلمة المرور" Style="{StaticResource FieldLabel}"/>
                            <PasswordBox x:Name="PbPassword" Style="{StaticResource ModernPasswordBox}"
                                         Margin="0,0,0,0"/>
                        </StackPanel>

                        <Border x:Name="WindowsAuthNotice" Background="#E8F5E9" CornerRadius="8"
                                Padding="12,10">
                            <TextBlock Text="&#x2713; سيتم استخدام بيانات مستخدم Windows الحالي للاتصال"
                                       FontFamily="Segoe UI" FontSize="12" Foreground="#2E7D32"
                                       TextWrapping="Wrap"/>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- Action Buttons -->
                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0" x:Name="BtnTest" Content="&#x1F50C;  اختبار الاتصال"
                            Style="{StaticResource PrimaryButton}"
                            Height="50" FontSize="16"
                            Click="BtnTest_Click"/>

                    <Button Grid.Column="2" x:Name="BtnSave" Content="&#x1F4BE;  حفظ الإعدادات"
                            Style="{StaticResource SecondaryButton}"
                            Height="50" MinWidth="140"
                            Click="BtnSave_Click"/>
                </Grid>

                <!-- Loading Indicator -->
                <Border x:Name="LoadingPanel" Visibility="Collapsed"
                        Background="White" CornerRadius="12" Padding="20,16"
                        Margin="0,0,0,16">
                    <Border.Effect>
                        <DropShadowEffect Color="#000000" Opacity="0.06" BlurRadius="12" ShadowDepth="2"/>
                    </Border.Effect>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock Text="&#x23F3;" FontSize="20" VerticalAlignment="Center" Margin="0,0,12,0"/>
                        <TextBlock Text="جاري اختبار الاتصال... يرجى الانتظار"
                                   FontFamily="Segoe UI" FontSize="14" Foreground="#1565C0"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- Result Panel -->
                <Border x:Name="ResultPanel" Visibility="Collapsed"
                        CornerRadius="12" Padding="20" Margin="0,0,0,8">
                    <Border.Effect>
                        <DropShadowEffect Color="#000000" Opacity="0.08" BlurRadius="12" ShadowDepth="2"/>
                    </Border.Effect>
                    <StackPanel>
                        <TextBlock x:Name="TxtResultIcon" FontSize="32"
                                   HorizontalAlignment="Center" Margin="0,0,0,8"/>
                        <TextBlock x:Name="TxtResultTitle" FontSize="18" FontWeight="Bold"
                                   HorizontalAlignment="Center" Margin="0,0,0,12"
                                   TextWrapping="Wrap" TextAlignment="Center"/>
                        <Separator Margin="0,0,0,12" Opacity="0.3"/>
                        <TextBlock x:Name="TxtResultDetail" FontFamily="Segoe UI" FontSize="13"
                                   TextWrapping="Wrap" TextAlignment="Right"
                                   LineHeight="22" Foreground="#37474F"/>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- Footer -->
        <Border Grid.Row="2" Background="#ECEFF1" Padding="16,10">
            <TextBlock Text="SQL Connection Tester v1.0  •  بدون كلمة مرور يتم الحفظ  •  .NET 8 + WPF"
                       FontFamily="Segoe UI" FontSize="11" Foreground="#90A4AE"
                       HorizontalAlignment="Center"/>
        </Border>
    </Grid>
</Window>
